# Copy this to .env and fill in your key. Never commit .env.

# Google Gemini — get a free key at https://aistudio.google.com
# Free tier: 15 RPM, 1M tokens/day — no credit card required.
GEMINI_API_KEY=your_gemini_key_here

# Gemini models with tool calling support. Thinking is disabled in code
# (thinking_budget=0) for low latency, so a Flash-class model is ideal:
#   gemini-flash-lite-latest  <- default: fastest, rolling alias, low latency
#   gemini-flash-latest       <- a touch richer, slightly slower
#   gemini-2.5-flash          <- pinned name; its own small free daily quota
#   gemini-2.5-flash-lite     <- pinned lite name; its own small free daily quota
# Each pinned model carries a separate free daily quota, so if one is exhausted,
# switch to another here without touching code.
LLM_MODEL=gemini-flash-lite-latest

# Model used by the LLM-as-judge in the eval harness. Defaults to the same
# high-quota model as the agent; the judge spaces its calls out to stay under the
# per-minute limit. The pinned Flash models (gemini-2.5-flash / -2.0-flash) have
# their own separate but much smaller daily quotas — fine for a one-off judged run,
# but they exhaust quickly, so flash-lite-latest is the more reliable default.
JUDGE_MODEL=gemini-flash-lite-latest
