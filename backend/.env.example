# Copy this to .env and fill in your keys. Never commit .env.

# OpenRouter gives you access to free LLMs — sign up at openrouter.ai
# The free tier has no credit card required.
OPENROUTER_API_KEY=your_openrouter_key_here

# Free models that work well for this project (must support tool calling).
# Verify availability with: GET https://openrouter.ai/api/v1/models — the free
# catalog changes often, and a retired slug returns 404 "No endpoints found".
#   openai/gpt-oss-20b:free            <- default: fast (~2s) + reliable tools
#   z-ai/glm-4.5-air:free              <- a bit slower, warmer long-form prose
#   openai/gpt-oss-120b:free           <- larger but noticeably slower
#   meta-llama/llama-3.3-70b-instruct:free
# Paid alternatives if you add OpenRouter credits (faster + more reliable):
#   anthropic/claude-3.5-haiku
LLM_MODEL=openai/gpt-oss-20b:free

# Model used by the eval LLM-as-judge — kept separate so you can judge with a
# different model than the agent if you want a more neutral grader.
JUDGE_MODEL=openai/gpt-oss-20b:free

# Your app name — OpenRouter shows this in their dashboard
OPENROUTER_APP_NAME=aradhna-astroagent
